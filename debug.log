Run APP_PATH="build/HeartFloat.xcarchive/Products/Applications/HeartFloat.app"
  APP_PATH="build/HeartFloat.xcarchive/Products/Applications/HeartFloat.app"
  BINARY="$APP_PATH/HeartFloat"
  
  if [ ! -f "$BINARY" ]; then
    echo "::error::App binary not found"
    exit 1
  fi
  
  echo "=== Detecting linked Swift libraries ==="
  otool -L "$BINARY" | grep -i swift || echo "No swift libs found in otool output"
  
  SWIFT_LIB_DIR="$(xcrun --sdk iphoneos --show-sdk-path)/usr/lib/swift/iphoneos"
  echo "Swift lib source dir: $SWIFT_LIB_DIR"
  ls "$SWIFT_LIB_DIR"/libswift*.dylib 2>/dev/null | head -20 || echo "No swift dylibs in SDK!"
  
  mkdir -p "$APP_PATH/Frameworks"
  
  REQUIRED_LIBS=(
    "libswiftCore.dylib"
    "libswiftCoreFoundation.dylib"
    "libswiftFoundation.dylib"
    "libswiftObjectiveC.dylib"
    "libswiftSwiftOnoneSupport.dylib"
    "libswiftDispatch.dylib"
    "libswiftDarwin.dylib"
    "libswiftMath.dylib"
    "libswiftUIKit.dylib"
    "libswiftCoreGraphics.dylib"
    "libswiftQuartzCore.dylib"
  )
  
  EMBEDDED_COUNT=0
  for LIB in "${REQUIRED_LIBS[@]}"; do
    SRC="$SWIFT_LIB_DIR/$LIB"
    if [ -f "$SRC" ]; then
      cp "$SRC" "$APP_PATH/Frameworks/"
      chmod 755 "$APP_PATH/Frameworks/$LIB"
      echo "  ✅ Embedded: $LIB ($(du -h "$APP_PATH/Frameworks/$LIB" | cut -f1))"
      EMBEDDED_COUNT=$((EMBEDDED_COUNT + 1))
    else
      echo "  ⚠️ Not found: $LIB"
    fi
  done
  
  echo ""
  echo "=== Embedded $EMBEDDED_COUNT Swift libraries ==="
  echo "=== Frameworks directory contents ==="
  ls -lh "$APP_PATH/Frameworks/"
  shell: /bin/bash -e {0}
  
